# ── AgriSmart AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values

# Anthropic API Key (required for AI Advisor & Disease Detection)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port (default 3000)
PORT=3000

# Environment
NODE_ENV=development

# Optional: OpenWeatherMap API key for live weather
# Free tier at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: Default farm location (lat, lon)
FARM_LAT=20.0059
FARM_LON=73.7898
FARM_CITY=Nashik
